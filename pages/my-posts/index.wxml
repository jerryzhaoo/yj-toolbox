<view class="page">
  <view class="content">
    <!-- 列表内容 -->
    <block wx:if="{{posts.length > 0}}">
      <!-- 活动列表 -->
      <block wx:for="{{posts}}" wx:key="id">
        <view wx:if="{{isActivityType(item)}}" class="activity-card card" data-item="{{item}}" bindtap="onCardClick">
          <view class="card-image {{'style' + (item.styleIndex % 7)}}">
            <view class="status-badge {{item.isExpired ? 'badge-expired' : 'badge-active'}}">{{item.isExpired ? '已截止' : '进行中'}}</view>
            <view class="card-content">
              <text class="card-title">{{item.tag === '拼团' ? '拼团上车共赴精彩决斗！' : '优惠月卡等你来'}}</text>
              <view class="card-badge">满10人即可开团</view>
              <text class="card-desc">报名即享优惠</text>
            </view>
            <view class="card-icon">
              <image class="card-svg-icon" src="/assets/icons/car.svg" mode="aspectFit" />
            </view>
          </view>
          <view class="card-info">
            <view class="info-top">
              <view class="info-tags">
                <text class="tag {{item.isExpired ? 'tag-gray' : 'tag-yellow'}}">{{item.isExpired ? '已截止' : item.tag}}</text>
                <view class="type-tag">
                  <image class="type-svg-icon" src="/assets/icons/car-small.svg" mode="aspectFit" />
                  <text>{{item.type}}</text>
                </view>
              </view>
              <text class="date-text">{{item.date}} 至 {{item.endDate}}</text>
            </view>
            <view class="info-bottom">
              <view class="people-info">
                <view class="avatars">
                  <view class="avatar-circle blue"></view>
                  <view class="avatar-circle blue"></view>
                  <view class="avatar-circle blue"></view>
                </view>
                <text class="people-count {{item.isExpired ? 'gray' : 'orange'}}">{{item.people}}人已报名</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 普通帖子卡片 -->
        <view wx:else class="post-card card {{item.isExpired ? 'expired' : ''}}" data-item="{{item}}" bindtap="onCardClick">
          <view class="post-expired-badge {{item.isExpired ? 'badge-expired' : 'badge-active'}}">{{item.isExpired ? '已截止' : '进行中'}}</view>
          <view class="post-type-badge {{item.type}} {{item.isExpired ? 'expired' : ''}}">
            {{item.type === 'group' ? '拼团' : item.type === 'transfer' ? '月卡转让' : item.type === 'secondhand' ? '闲置二手' : item.type === 'job' ? '招聘信息' : item.type}}
          </view>
          <view class="post-content">
            <view class="post-left {{item.images && item.images.length > 0 ? '' : getImageStyle(item.imageStyle)}}">
              <image 
                wx:if="{{item.images && item.images.length > 0}}" 
                class="post-thumb-img" 
                src="{{item.images[0]}}" 
                mode="aspectFill" 
              />
              <view wx:else class="image-placeholder-box">
                <text class="placeholder-icon">{{item.type === 'transfer' ? '🔄' : item.type === 'secondhand' ? '🏷️' : item.type === 'job' ? '💼' : '🚗'}}</text>
                <text class="placeholder-label">{{item.type === 'transfer' ? '月卡转让' : item.type === 'secondhand' ? '闲置二手' : item.type === 'job' ? '招聘信息' : '拼团活动'}}</text>
              </view>
            </view>
            <view class="post-right">
              <text class="post-title">{{item.title}}</text>
              <text class="post-desc">{{item.description}}</text>
              <view class="post-meta">
                <text class="meta-item">◉ {{item.location}}</text>
                <text class="meta-item">⏱ {{item.time}}</text>
              </view>
              <text wx:if="{{item.price}}" class="post-price">¥{{item.price}}</text>
            </view>
          </view>
        </view>
      </block>
    </block>

    <!-- 加载中 -->
    <block wx:if="{{loading}}">
      <view class="loading-state">
        <text class="loading-text">加载中...</text>
      </view>
    </block>

    <!-- 空状态 -->
    <block wx:elif="{{posts.length === 0}}">
      <view class="empty-state">
        <view class="empty-icon-box">
          <text class="empty-icon-text">∅</text>
        </view>
        <text class="empty-title">暂无内容</text>
        <text class="empty-desc">
          {{type === 'posts' ? '快去发布你的第一条信息吧' : type === 'joined' ? '快去参加活动吧' : '快去收藏喜欢的内容吧'}}
        </text>
      </view>
    </block>
  </view>
</view>