/* 页面容器 */
.page {
  min-height: 100vh;
  background: #F5F4FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ====== 头部渐变区域 ====== */
.header-gradient {
  background: linear-gradient(150deg, #6D28D9, #A855F7, #EC4899);
  border-radius: 0 0 28px 28px;
  padding: 24px 20px 20px;
  position: relative;
  z-index: 1;
}

/* 用户信息行 */
.user-row {
  display: flex;
  align-items: center;
  gap: 16px;
}

.avatar-wrap {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  border: 3px solid rgba(255, 255, 255, 0.5);
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 32px;
  height: 32px;
  opacity: 0.7;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.user-name {
  font-size: 20px;
  font-weight: 800;
  color: #ffffff;
}

.user-gender-tag {
  font-size: 10px;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4px;
  padding: 2px 8px;
  line-height: 1.6;
}

.edit-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: rgba(255, 255, 255, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.25);
  border-radius: 30px;
  padding: 5px 14px;
  align-self: flex-start;
}

.edit-btn-icon {
  font-size: 11px;
  color: #ffffff;
}

.edit-btn-text {
  font-size: 11px;
  color: #ffffff;
}

/* 统计数据块 */
.stats-block {
  display: flex;
  align-items: center;
  margin: 20px 20px 0;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16px;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 0;
}

.stat-divider {
  width: 1px;
  height: 32px;
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.stat-count {
  font-size: 20px;
  font-weight: 800;
  color: #ffffff;
}

.stat-label {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 2px;
}

/* ====== 菜单列表区域 ====== */
.menu-area {
  padding-top: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.menu-card {
  background: #ffffff;
  border-radius: 16px;
  margin: 0 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
}

.divider {
  height: 1px;
  background: #F5F5F8;
  margin-left: 60px;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
}

.menu-icon {
  width: 36px;
  height: 36px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-svg {
  width: 18px;
  height: 18px;
}

.menu-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 2px;
  flex: 1;
}

.menu-title {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A2E;
}

.menu-subtitle {
  font-size: 11px;
  color: #BDBDBD;
}

.menu-arrow {
  font-size: 18px;
  color: #D1D5DB;
  flex-shrink: 0;
}

/* 图标颜色 */
.purple-bg {
  background: #EDE9FE;
}
.purple-bg .menu-svg {
  color: #8B5CF6;
}

.blue-bg {
  background: #DBEAFE;
}
.blue-bg .menu-svg {
  color: #3B82F6;
}

.pink-bg {
  background: #FCE7F3;
}
.pink-bg .menu-svg {
  color: #EC4899;
}

.green-bg {
  background: #D1FAE5;
}
.green-bg .menu-svg {
  color: #10B981;
}

.yellow-bg {
  background: #FEF3C7;
}
.yellow-bg .menu-svg {
  color: #F59E0B;
}

/* ====== 管理员配置弹窗 ====== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.admin-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 201;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.admin-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.admin-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.admin-modal-close {
  font-size: 32rpx;
  color: #9CA3AF;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-list {
  padding: 12rpx 0;
  max-height: 400rpx;
  overflow-y: auto;
}

.admin-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
}

.admin-item:not(:last-child) {
  border-bottom: 1rpx solid #F9FAFB;
}

.admin-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.admin-wechat {
  font-size: 28rpx;
  color: #374151;
}

.admin-role {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.role-super {
  background: #FEF3C7;
  color: #B45309;
}

.role-admin {
  background: #DBEAFE;
  color: #1D4ED8;
}

.role-pending {
  background: #FEF3C7;
  color: #D97706;
}

.admin-remove {
  font-size: 24rpx;
  color: #EF4444;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #FEF2F2;
}

.remove-disabled {
  color: #D1D5DB;
  background: #F9FAFB;
  pointer-events: none;
}

.admin-empty {
  padding: 40rpx;
  text-align: center;
  color: #9CA3AF;
  font-size: 26rpx;
}

.add-admin-section {
  padding: 20rpx 28rpx 32rpx;
  border-top: 1rpx solid #F3F4F6;
}

.add-admin-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: #3B82F6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
}

.add-admin-form {
  padding: 20rpx 28rpx 32rpx;
  border-top: 1rpx solid #F3F4F6;
}

.form-row {
  margin-bottom: 12rpx;
}

.wechat-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #F9FAFB;
}

.wechat-input:focus {
  border-color: #3B82F6;
  background: #fff;
}

.form-error {
  font-size: 22rpx;
  color: #EF4444;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.form-actions {
  display: flex;
  gap: 16rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
}

.btn-cancel {
  background: #F3F4F6;
  color: #6B7280;
}

.btn-confirm {
  background: #3B82F6;
  color: #fff;
}

/* ====== 邀请码弹窗 ====== */
.modal-mask-invite {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  background: rgba(0, 0, 0, 0.3);
}

.invite-modal {
  position: fixed;
  top: 25%;
  left: 50%;
  transform: translateX(-50%);
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  z-index: 2100;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: fadeInModal 0.25s ease-out;
  width: 85%;
  max-width: 560rpx;
}

@keyframes fadeInModal {
  from { opacity: 0; transform: translateX(-50%) translateY(-30rpx); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.invite-code-box {
  background: #F3F4F6;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  margin: 20rpx 0;
}

.invite-code-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #3B82F6;
  letter-spacing: 12rpx;
}

.invite-tip {
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.invite-tip text {
  font-size: 24rpx;
  color: #888888;
}

.copy-code-btn {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  background: #3B82F6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  text-align: center;
}

/* ====== 社群信息弹窗 ====== */
.comm-modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 40rpx; }
.comm-modal { width: 100%; max-width: 520rpx; background: linear-gradient(135deg, #2D3361, #1E234A); border-radius: 24rpx; padding: 20rpx 20rpx 16rpx; box-shadow: 0 8rpx 32rpx rgba(30,35,74,0.4); }
.comm-header { display: flex; justify-content: space-between; margin-bottom: 20rpx; }
.comm-title { font-size: 30rpx; font-weight: bold; color: #fff; display: block; }
.comm-subtitle { font-size: 20rpx; color: rgba(255,255,255,0.45); margin-top: 4rpx; display: block; }
.comm-header-right { display: flex; align-items: flex-start; gap: 12rpx; padding-top: 4rpx; }
.comm-edit { font-size: 20rpx; color: rgba(255,255,255,0.55); padding: 4rpx 12rpx; border: 1rpx solid rgba(255,255,255,0.2); border-radius: 24rpx; }
.comm-close { width: 40rpx; height: 40rpx; border-radius: 50%; background: rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: rgba(255,255,255,0.45); }
.comm-empty { text-align: center; padding: 48rpx 0; color: rgba(255,255,255,0.35); font-size: 22rpx; }
.comm-empty-tip { display: block; font-size: 18rpx; color: rgba(255,255,255,0.2); margin-top: 8rpx; }

.comm-tabs { display: flex; gap: 10rpx; justify-content: center; margin-bottom: 30rpx; }
.comm-tab { padding: 8rpx 24rpx; border-radius: 32rpx; font-size: 22rpx; color: rgba(255,255,255,0.45); background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.08); }
.comm-tab.active { color: #fff; border-color: #818CF8; background: rgba(129,140,248,0.12); }

.comm-badge-dot { width: 8rpx; height: 8rpx; border-radius: 50%; display: inline-block; }
.comm-badge-dot.open { background: #4ADE80; }
.comm-badge-dot.full { background: #9CA3AF; }

.comm-swiper { width: 100%; height: 380rpx; }
.comm-card { width: 100%; display: flex; flex-direction: column; align-items: center; }

.comm-qr-wrap { width: 260rpx; height: 260rpx; background: #fff; border-radius: 12rpx; padding: 10rpx; margin-bottom: 8rpx; position: relative; overflow: hidden; }
.comm-qr-wrap.full { filter: grayscale(1); }
.comm-qr { width: 100%; height: 100%; }
.comm-qr-empty { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; color: #999; }
.comm-qr-mask { position: absolute; inset: 0; background: rgba(0,0,0,0.55); display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 12rpx; }
.qr-mask-icon { font-size: 40rpx; margin-bottom: 6rpx; }
.qr-mask-title { font-size: 24rpx; font-weight: bold; color: #fff; margin-bottom: 4rpx; }
.qr-mask-sub { font-size: 18rpx; color: rgba(255,255,255,0.6); }

.comm-name-row { display: flex; align-items: center; justify-content: center; gap: 8rpx; margin-top: 16rpx; margin-bottom: 6rpx; }
.comm-name { font-size: 26rpx; font-weight: bold; color: #fff; }
.comm-inline-tag { padding: 2rpx 12rpx; border-radius: 8rpx; font-size: 18rpx; font-weight: 500; }
.comm-inline-tag.open { background: rgba(74,222,128,0.15); color: #4ADE80; }
.comm-inline-tag.full { background: rgba(156,163,175,0.15); color: #9CA3AF; }

.comm-status-text { display: block; font-size: 20rpx; text-align: center; margin-bottom: 20rpx; }
.comm-status-text.open { color: rgba(255,255,255,0.5); }
.comm-status-text.full { color: rgba(255,255,255,0.3); }

.comm-nav { display: flex; align-items: center; justify-content: space-between; margin-top: 6rpx; }
.comm-nav-btn { padding: 8rpx 16rpx; border-radius: 24rpx; font-size: 20rpx; color: rgba(255,255,255,0.45); border: 1rpx solid rgba(255,255,255,0.1); }
.comm-nav-btn.disabled { opacity: 0.25; }
.comm-dots { display: flex; gap: 6rpx; align-items: center; }
.comm-dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: rgba(255,255,255,0.15); }
.comm-dot.active { width: 20rpx; border-radius: 4rpx; background: rgba(255,255,255,0.5); }

.comm-footer { text-align: center; font-size: 18rpx; color: rgba(255,255,255,0.25); margin-top: 14rpx; line-height: 1.5; }

.comm-edit-body { max-height: 360rpx; overflow-y: auto; }
.comm-edit-list { display: flex; flex-direction: column; gap: 10rpx; }
.comm-edit-item { background: rgba(255,255,255,0.08); border-radius: 12rpx; padding: 14rpx; }
.comm-edit-h { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }
.comm-edit-label { font-size: 22rpx; font-weight: bold; color: rgba(255,255,255,0.8); }
.comm-edit-del { font-size: 20rpx; color: #EF4444; padding: 2rpx 8rpx; }
.comm-edit-row { margin-bottom: 8rpx; }
.comm-edit-row:last-child { margin-bottom: 0; }
.comm-edit-l { display: block; font-size: 20rpx; color: rgba(255,255,255,0.45); margin-bottom: 4rpx; }
.comm-edit-inp { width: 100%; height: 52rpx; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 8rpx; padding: 0 12rpx; font-size: 22rpx; color: #fff; box-sizing: border-box; }
.comm-edit-upload { display: flex; align-items: center; gap: 8rpx; flex-wrap: wrap; }
.comm-edit-thumb { width: 80rpx; height: 80rpx; border-radius: 8rpx; }
.comm-edit-upbtn { font-size: 20rpx; color: rgba(255,255,255,0.6); padding: 8rpx 16rpx; border: 1rpx solid rgba(255,255,255,0.2); border-radius: 8rpx; }
.comm-edit-upbtn.del { color: rgba(255,100,100,0.7); border-color: rgba(255,100,100,0.25); }
.comm-edit-switch { display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.comm-edit-switch .comm-edit-l { margin-bottom: 0; }
.comm-edit-add { display: flex; align-items: center; justify-content: center; height: 56rpx; border: 1rpx dashed rgba(255,255,255,0.2); border-radius: 10rpx; font-size: 22rpx; color: rgba(255,255,255,0.5); }
.comm-edit-ft { display: flex; gap: 10rpx; margin-top: 12rpx; }
.comm-edit-cancel { flex: 1; height: 56rpx; border-radius: 28rpx; background: rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: rgba(255,255,255,0.5); }
.comm-edit-save { flex: 1; height: 56rpx; border-radius: 28rpx; background: linear-gradient(135deg, #6366F1, #8B5CF6); display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; color: #fff; }

/* ====== 底部导航栏 ====== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  border-top: 1rpx solid #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  height: 100%;
  padding: 0;
}

.tab-item.active .tab-icon .nav-svg-icon {
  color: #111827;
}

.tab-item.active .tab-text {
  color: #111827;
  font-weight: 500;
}

.tab-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-svg-icon {
  width: 48rpx;
  height: 48rpx;
  color: #6B7280;
}

.tab-text {
  font-size: 22rpx;
  color: #6B7280;
}

.tab-center {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  margin-top: -32rpx;
}

.center-btn {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FFE500, #FDE047, #FCD34D);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(251, 191, 36, 0.3);
  transform: rotate(45deg);
}

.plus-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.plus-h {
  position: absolute;
  width: 36rpx;
  height: 6rpx;
  background: #111827;
  border-radius: 3rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
}

.plus-v {
  position: absolute;
  width: 6rpx;
  height: 36rpx;
  background: #111827;
  border-radius: 3rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
}

.tab-item:active, .tab-center:active {
  opacity: 0.7;
}

/* ====== 版本信息 ====== */
.version-card {
  margin-top: 4px;
}

.version-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
}

.version-info {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
}

.version-label {
  font-size: 13px;
  color: #9CA3AF;
  flex-shrink: 0;
}

.version-text {
  font-size: 14px;
  font-weight: 500;
  color: #374151;
}

.version-env {
  font-size: 11px;
  color: #fff;
  background: #6366F1;
  padding: 2px 10px;
  border-radius: 10px;
  flex-shrink: 0;
}

.check-update-btn {
  font-size: 12px;
  color: #6366F1;
  background: #EEF2FF;
  border: none;
  border-radius: 8px;
  padding: 8px 18px;
  line-height: 1.4;
  flex-shrink: 0;
}

/* ====== 其他 ====== */
.center-btn-disabled {
  opacity: 0.35;
  pointer-events: none;
}

.plus-disabled {
  opacity: 0.4;
}
