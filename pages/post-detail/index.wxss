/* 页面容器 */
.page {
  min-height: 100vh;
  background: #F5F4FA;
  padding-bottom: 140rpx;
}

/* loading 骨架屏 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 120rpx);
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.98);
  border-bottom: 1rpx solid #E5E7EB;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #555555;
  font-weight: bold;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.action-btn.blue {
  background: #DBEAFE;
}

.action-btn.red {
  background: #FEE2E2;
}

/* 内容区域 */
.content {
  padding: 16rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

/* 主要信息卡片 */
.type-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.type-tag {
  font-size: 22rpx;
  font-weight: 500;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.type-tag.blue {
  background: #DBEAFE;
  color: #2563EB;
}

.type-tag.gray {
  background: #F3F4F6;
  color: #6B7280;
}

.post-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.price-box {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.price-label {
  font-size: 24rpx;
  color: #888888;
  margin-right: 6rpx;
}

.price-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #F97316;
}

.price-unit {
  font-size: 24rpx;
  color: #888888;
  margin-left: 6rpx;
}

.price-original {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.post-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #888888;
  white-space: nowrap;
}

.meta-icon-wrap {
  width: 24rpx;
  height: 24rpx;
}

.meta-svg-icon {
  width: 20rpx;
  height: 20rpx;
}

/* 图片展示 */
.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-item {
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: #F3F4F6;
}

.detail-image {
  width: 100%;
  display: block;
}

/* 图片占位符多样化背景模板 */
.image-item.gradient-0 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.image-item.gradient-0::before {
  content: '';
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
}

.image-item.gradient-1 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.image-item.gradient-1::before {
  content: '';
  position: absolute;
  top: -40rpx;
  left: -30rpx;
  width: 90rpx;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.image-item.gradient-2 {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.image-item.gradient-3 {
  background: radial-gradient(circle at 30% 30%, #4facfe 0%, #00f2fe 100%);
}

.img-placeholder-box {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.img-placeholder-box .placeholder-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  font-weight: 500;
}

/* 详细描述 */
.desc-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.7;
}

/* 详细信息 */
.details-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-item {
  display: flex;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.detail-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.detail-key {
  width: 140rpx;
  font-size: 24rpx;
  color: #888888;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
}

/* 发布者信息 */
.publisher-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.publisher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #60A5FA, #8B5CF6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-svg {
  width: 40rpx;
  height: 40rpx;
}

.publisher-detail {
  flex: 1;
}

.publisher-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
}

.publisher-type {
  display: block;
  font-size: 22rpx;
  color: #888888;
}

/* 联系方式 */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F0FDF4;
  border-radius: 12rpx;
  padding: 16rpx;
}

.contact-item.blue {
  background: #EFF6FF;
}

.contact-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.contact-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contact-svg {
  width: 28rpx;
  height: 28rpx;
}

.green-bg {
  background: #22C55E;
}

.blue-bg {
  background: #3B82F6;
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.contact-label {
  font-size: 22rpx;
  color: #888888;
}

.contact-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}

.contact-btn {
  background: #22C55E;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
}

.contact-btn.blue-btn {
  background: #3B82F6;
}

/* 温馨提示 */
.tips-box {
  background: #FEF3C7;
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 12rpx;
}

.tips-title {
  display: block;
  font-size: 22rpx;
  font-weight: bold;
  color: #92400E;
  margin-bottom: 8rpx;
}

.tips-item {
  display: block;
  font-size: 20rpx;
  color: #B45309;
  margin-bottom: 4rpx;
  line-height: 1.4;
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #E5E7EB;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.author-actions {
  display: flex;
  gap: 16rpx;
}

.btn-edit {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-delete {
  padding: 24rpx 36rpx;
  background: linear-gradient(135deg, #EF4444, #DC2626);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.user-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.contact-btn-full {
  flex: 1;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

