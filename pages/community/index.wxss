.page { min-height: 100vh; background: linear-gradient(180deg, #F0F4FF 0%, #E8EEF8 100%); display: flex; flex-direction: column; align-items: center; }
.page-masked { height: 100vh; overflow: hidden; }
.loading-wrap { display: flex; align-items: center; justify-content: center; height: 60vh; }
.loading-text { font-size: 28rpx; color: #999; }

/* 顶部 */
.header-section { padding: 40rpx 32rpx 20rpx; text-align: center; }
.header-title { font-size: 36rpx; font-weight: bold; color: #1F2937; }
.header-subtitle { display: block; font-size: 24rpx; color: #9CA3AF; margin-top: 8rpx; }

/* Tab 栏 */
.tab-bar { display: flex; gap: 12rpx; padding: 0 32rpx 20rpx; }
.tab-item { display: flex; align-items: center; gap: 4rpx; padding: 12rpx 28rpx; border-radius: 40rpx; font-size: 26rpx; color: #6B7280; background: #fff; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05); }
.tab-item.active { color: #fff; background: linear-gradient(135deg, #6366F1, #8B5CF6); font-weight: 600; box-shadow: 0 4rpx 12rpx rgba(99,102,241,0.3); }
.tab-dot { font-size: 16rpx; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 0; }
.empty-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.empty-tip { font-size: 22rpx; color: #c0c0c0; margin-top: 8rpx; }

/* 轮播 */
.group-swiper { width: 100%; height: auto; min-height: 560rpx; padding: 0 24rpx; box-sizing: border-box; }

/* 群卡片 - 深色背景 */
.group-card { margin: 0 8rpx; background: linear-gradient(135deg, #2D3361, #1E234A); border-radius: 28rpx; padding: 32rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 8rpx 32rpx rgba(30,35,74,0.35); }

/* 二维码 */
.qr-wrap { width: 400rpx; height: 400rpx; border-radius: 16rpx; overflow: hidden; background: #fff; padding: 16rpx; margin-bottom: 24rpx; }
.qr-image { width: 100%; height: 100%; }
.qr-placeholder { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #F9FAFB; border-radius: 12rpx; }
.qr-placeholder-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.qr-placeholder-text { font-size: 22rpx; color: #9CA3AF; }

/* 群信息 */
.group-info { width: 100%; text-align: center; }
.group-name-row { display: flex; align-items: center; justify-content: center; gap: 12rpx; margin-bottom: 8rpx; }
.group-name { font-size: 30rpx; font-weight: bold; color: #ffffff; }
.copy-btn { display: flex; align-items: center; gap: 4rpx; padding: 6rpx 16rpx; border-radius: 30rpx; background: rgba(255,255,255,0.15); font-size: 22rpx; color: rgba(255,255,255,0.8); }
.copy-icon { font-size: 20rpx; }
.group-desc { display: block; font-size: 24rpx; color: rgba(255,255,255,0.55); }

/* 导航按钮 */
.nav-bar { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 24rpx 32rpx; box-sizing: border-box; }
.nav-btn { display: flex; align-items: center; gap: 8rpx; padding: 16rpx 24rpx; border-radius: 40rpx; background: #fff; font-size: 24rpx; color: #4B5563; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05); }
.nav-btn.disabled { opacity: 0.4; }
.nav-arrow { font-size: 32rpx; }
.nav-dots { display: flex; gap: 8rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #D1D5DB; }
.dot.active { width: 28rpx; border-radius: 6rpx; background: linear-gradient(135deg, #6366F1, #8B5CF6); }

/* 底部提示 */
.footer-tip { display: flex; align-items: flex-start; gap: 12rpx; margin: 24rpx 32rpx 120rpx; padding: 20rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); width: calc(100% - 64rpx); box-sizing: border-box; }
.tip-icon { font-size: 28rpx; flex-shrink: 0; }
.tip-content { flex: 1; }
.tip-line { display: block; font-size: 22rpx; color: #6B7280; line-height: 1.6; }
.tip-line.sub { color: #9CA3AF; margin-top: 4rpx; }

/* 管理员编辑按钮 */
.edit-fab { position: fixed; right: 32rpx; bottom: 100rpx; width: 96rpx; height: 96rpx; border-radius: 50%; background: linear-gradient(135deg, #6366F1, #8B5CF6); display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 16rpx rgba(99,102,241,0.4); z-index: 50; }
.edit-fab-icon { font-size: 36rpx; color: #fff; }

/* 编辑弹窗（从底部滑出） */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: flex-end; justify-content: center; }
.modal-sheet { width: 100%; max-height: 80vh; background: #fff; border-radius: 32rpx 32rpx 0 0; display: flex; flex-direction: column; }
.modal-handle { width: 48rpx; height: 6rpx; border-radius: 3rpx; background: #D1D5DB; align-self: center; margin: 16rpx auto; }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 0 32rpx 16rpx; border-bottom: 1rpx solid #F3F4F6; }
.modal-title { font-size: 30rpx; font-weight: bold; color: #333; }
.modal-close { width: 48rpx; height: 48rpx; border-radius: 50%; background: #F3F4F6; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #888; }
.modal-body { flex: 1; overflow-y: auto; padding: 16rpx 32rpx; }
.modal-footer { padding: 16rpx 32rpx 32rpx; }
.save-btn { height: 80rpx; border-radius: 40rpx; background: linear-gradient(135deg, #6366F1, #8B5CF6); color: #fff; font-size: 28rpx; font-weight: bold; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 12rpx rgba(99,102,241,0.3); }

/* 编辑列表 */
.edit-list { display: flex; flex-direction: column; gap: 16rpx; }
.edit-item { background: #F9FAFB; border-radius: 16rpx; padding: 20rpx; }
.edit-item-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.edit-item-label { font-size: 24rpx; font-weight: bold; color: #333; }
.edit-item-del { font-size: 22rpx; color: #EF4444; padding: 4rpx 12rpx; }
.edit-form { display: flex; flex-direction: column; gap: 12rpx; }
.edit-row { display: flex; flex-direction: column; gap: 4rpx; }
.edit-label { font-size: 22rpx; color: #888; }
.edit-input { width: 100%; height: 60rpx; background: #fff; border: 1rpx solid #E5E7EB; border-radius: 8rpx; padding: 0 12rpx; font-size: 24rpx; box-sizing: border-box; color: #333; }
.edit-upload { display: flex; align-items: center; gap: 12rpx; }
.edit-thumb { width: 100rpx; height: 100rpx; border-radius: 8rpx; }
.edit-upload-btn { font-size: 22rpx; color: #3B82F6; padding: 10rpx 20rpx; border: 1rpx solid #3B82F6; border-radius: 8rpx; }
.edit-upload-btn.del { color: #EF4444; border-color: #EF4444; }
.add-btn { display: flex; align-items: center; justify-content: center; gap: 8rpx; height: 80rpx; border: 2rpx dashed #D1D5DB; border-radius: 12rpx; font-size: 26rpx; color: #3B82F6; margin-top: 8rpx; }
.add-icon { font-size: 32rpx; }
