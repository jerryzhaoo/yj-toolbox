.container {
  padding: 40rpx;
  min-height: 100vh;
  background: #E8F4F8;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.btn {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 24rpx;
}

.btn-primary {
  background: #3B82F6;
  color: #fff;
}

.btn-success {
  background: #10B981;
  color: #fff;
}

.btn-purple {
  background: #8B5CF6;
  color: #fff;
}

.btn[disabled] {
  opacity: 0.6;
}

.result {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  white-space: pre-wrap;
}
