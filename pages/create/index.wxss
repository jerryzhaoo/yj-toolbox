/* 页面容器 */
.page {
  min-height: 100vh;
  background: #F5F4FA;
  padding-bottom: 120rpx;
}

/* loading */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* 头部导航 - 毛玻璃效果 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid #E5E7EB;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #374151;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
}

.publish-btn {
  background: #3B82F6;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
}

/* 类型选择标签 */
.type-tabs {
  padding: 16rpx 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #E5E7EB;
}

.tabs {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.tab {
  padding: 10rpx 20rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #374151;
  background: #F3F4F6;
  white-space: nowrap;
  transition: all 0.2s;
}

.tab.active {
  background: #3B82F6;
  color: #ffffff;
}

/* 编辑模式当前类型 */
.current-type {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
}

.current-type-text {
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 500;
}

/* 内容区域 */
.content {
  padding: 16rpx;
}

/* 表单卡片 */
.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.form-title {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 8rpx;
}

.required {
  color: #EF4444;
  font-weight: 500;
  margin-right: 4rpx;
}

.form-label-small {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 6rpx;
}

.form-input {
  width: 100%;
  font-size: 26rpx;
  line-height: 1.4;
  height: 60rpx;
  color: #111827;
  background: #F9FAFB;
  border-radius: 10rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
}

/* ===== 隐私授权弹窗（发布页） ===== */
.publish-privacy-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}
.publish-privacy-modal {
  width: 100%;
  max-height: 70vh;
  background: #ffffff;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.publish-privacy-modal .pp-header {
  padding: 36rpx 32rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #F3F4F6;
}
.publish-privacy-modal .pp-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #111827;
  display: block;
  margin-bottom: 12rpx;
}
.publish-privacy-modal .pp-subtitle {
  font-size: 24rpx;
  color: #6B7280;
  display: block;
  line-height: 1.6;
}
.publish-privacy-modal .pp-body {
  flex: 1;
  padding: 16rpx 32rpx;
  max-height: 500rpx;
}
.publish-privacy-modal .pp-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F9FAFB;
}
.publish-privacy-modal .pp-item:last-child {
  border-bottom: none;
}
.publish-privacy-modal .pp-item-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}
.publish-privacy-modal .pp-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #1F2937;
}
.publish-privacy-modal .pp-purpose {
  font-size: 22rpx;
  color: #6B7280;
  line-height: 1.5;
  display: block;
  word-break: break-all;
  overflow-wrap: break-word;
}
.publish-privacy-modal .pp-note {
  margin-top: 12rpx;
  padding: 14rpx;
  background: #FFF7ED;
  border-radius: 12rpx;
}
.publish-privacy-modal .pp-note-text {
  font-size: 20rpx;
  color: #9A3412;
  line-height: 1.5;
  display: block;
}
.publish-privacy-modal .pp-footer {
  display: flex;
  padding: 16rpx 32rpx 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid #F3F4F6;
  flex-shrink: 0;
}
.publish-privacy-modal .pp-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}
.publish-privacy-modal .pp-btn-disagree {
  background: #F3F4F6;
  color: #6B7280;
}
.publish-privacy-modal .pp-btn-agree {
  background: linear-gradient(135deg, #3B82F6, #6366F1);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.placeholder {
  color: #9CA3AF;
}

/* 地图选点 */
.location-picker {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  width: 100%;
  min-height: 80rpx;
  background: #F9FAFB;
  border-radius: 10rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

