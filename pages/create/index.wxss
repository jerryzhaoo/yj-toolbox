/* 开关 */
.switch-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-left {
  flex: 1;
}

.switch-title {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #374151;
}

.switch-desc {
  display: block;
  font-size: 20rpx;
  color: #9CA3AF;
}

.switch-btn {
  position: relative;
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  transition: all 0.2s;
}

.switch-btn.on {
  background: linear-gradient(135deg, #3B82F6, #2563EB);
}

.switch-btn.off {
  background: #D1D5DB;
}

.switch-handle {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s;
}

.switch-btn.off .switch-handle {
  transform: translateX(40rpx);
}

/* 图片上传 */
.upload-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-left: 8rpx;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.upload-item {
  width: calc(33.333% - 8rpx);
  aspect-ratio: 1;
  position: relative;
}

.upload-preview {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 500;
}

.upload-preview-img {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

.remove-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-btn text {
  color: #ffffff;
  font-size: 18rpx;
}

.upload-add {
  width: calc(33.333% - 8rpx);
  aspect-ratio: 1;
  background: #F3F4F6;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.upload-plus-svg {
  width: 36rpx;
  height: 36rpx;
}

.add-text {
  font-size: 20rpx;
  color: #9CA3AF;
}

/* 成功弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal-content {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.success-modal {
  text-align: center;
  padding: 40rpx 28rpx;
}

.success-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ADE80, #22C55E);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.check-icon {
  font-size: 50rpx;
  color: #ffffff;
}

.success-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 10rpx;
}

.success-desc {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.success-tip {
  background: #EFF6FF;
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 20rpx;
  text-align: left;
}

.success-tip text {
  font-size: 20rpx;
  color: #1E40AF;
  line-height: 1.4;
}

.btn-know {
  background: #3B82F6;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 20rpx;
  border-radius: 50rpx;
}

/* 渐变背景 */
.gradient-0 { background: linear-gradient(135deg, #60A5FA, #3B82F6); }
.gradient-1 { background: linear-gradient(135deg, #34D399, #10B981); }
.gradient-2 { background: linear-gradient(135deg, #FBBF24, #F59E0B); }
.gradient-3 { background: linear-gradient(135deg, #F472B6, #EC4899); }
.gradient-4 { background: linear-gradient(135deg, #A78BFA, #8B5CF6); }
