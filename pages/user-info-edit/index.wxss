/* 页面背景 */
.page {
  min-height: 100vh;
  background: #F5F4FA;
  padding-bottom: 40rpx;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid #E5E7EB;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.header-left {
  width: 60rpx;
}

.back-icon {
  font-size: 48rpx;
  color: #374151;
  font-weight: bold;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
}

.header-right {
  min-width: 80rpx;
  text-align: right;
}

.save-btn {
  font-size: 28rpx;
  color: #9CA3AF;
}

.save-btn.active {
  color: #3B82F6;
}

/* 用户信息卡片 */
.user-card {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 60rpx;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #3B82F6;
  color: #ffffff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-tip {
  margin-top: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 信息网格 */
.info-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #374151;
  flex-shrink: 0;
}

.info-value {
  font-size: 30rpx;
  color: #111827;
}

.info-value.placeholder {
  color: #D1D5DB;
}

.info-input {
  flex: 1;
  font-size: 30rpx;
  color: #111827;
  text-align: right;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-left: 24rpx;
}

/* 性别选择 */
.gender-select {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #6B7280;
  background: #F3F4F6;
  border: 2rpx solid #E5E7EB;
}

.gender-btn.active {
  color: #3B82F6;
  background: #EFF6FF;
  border-color: #3B82F6;
}

/* 发票类型选择 */
.invoice-type-select {
  display: flex;
  gap: 16rpx;
}

.invoice-type-btn {
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #6B7280;
  background: #F3F4F6;
  border: 2rpx solid #E5E7EB;
}

.invoice-type-btn.active {
  color: #3B82F6;
  background: #EFF6FF;
  border-color: #3B82F6;
}

/* 生日选择器 */
.birthday-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.birthday-picker .arrow {
  color: #D1D5DB;
  font-size: 28rpx;
}

/* 详细信息卡片 */
.detail-card {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  padding: 20rpx 32rpx;
  background: #F9FAFB;
  border-bottom: 1rpx solid #F3F4F6;
}

.card-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #374151;
}

.card-title.highlight {
  color: #3B82F6;
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.form-row.last {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #374151;
  flex-shrink: 0;
}

.form-label.off {
  color: #9CA3AF;
}

.required {
  color: #EF4444;
  margin-right: 4rpx;
}

.form-value {
  font-size: 30rpx;
  color: #111827;
}

.form-value.placeholder {
  color: #D1D5DB;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #111827;
  text-align: right;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-left: 24rpx;
}

/* 开关 */
.switch-btn {
  position: relative;
  width: 96rpx;
  height: 56rpx;
  border-radius: 28rpx;
  transition: all 0.2s;
}

.switch-btn.on {
  background: linear-gradient(135deg, #3B82F6, #2563EB);
}

.switch-btn.off {
  background: #D1D5DB;
}

.switch-btn.disabled {
  opacity: 0.6;
}

.switch-handle {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s;
}

.switch-btn.off .switch-handle {
  transform: translateX(40rpx);
}

/* 温馨提示 */
.tips {
  margin: 24rpx;
  background: #EFF6FF;
  border-radius: 20rpx;
  padding: 24rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #1E40AF;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-item {
  font-size: 22rpx;
  color: #3B82F6;
  line-height: 1.6;
}

/* 底部编辑/保存按钮 */
.bottom-actions {
  padding: 40rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
}
.bottom-btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
}
.bottom-btn.edit-btn {
  background: linear-gradient(135deg, #3B82F6, #6366F1);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}
.bottom-btn.save-btn {
  background: linear-gradient(135deg, #10B981, #059669);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}
