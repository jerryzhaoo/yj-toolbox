/* 兼容旧样式 - 保留以防其他地方引用 */
.image-style0 {
  background: linear-gradient(135deg, #60A5FA, #22D3EE);
}

.image-style1 {
  background: linear-gradient(135deg, #A78BFA, #F472B6);
}

.image-style2 {
  background: linear-gradient(135deg, #FB923C, #F87171);
}

.image-style3 {
  background: linear-gradient(135deg, #4ADE80, #34D399);
}

.image-style4 {
  background: linear-gradient(135deg, #818CF8, #60A5FA);
}

.image-style5 {
  background: linear-gradient(135deg, #FB7185, #F472B6);
}

.image-style6 {
  background: linear-gradient(135deg, #60A5FA, #3B82F6);
}

.image-expired {
  background: linear-gradient(135deg, #9CA3AF, #6B7280, #4B5563);
}

/* 卡片图片伪元素已移除，新模板自带装饰 */

.expired-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.expired-text {
  background: rgba(0, 0, 0, 0.8);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
}

.card-content {
  position: relative;
  z-index: 2;
  height: 100%;
  padding: 18rpx 28rpx 14rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.card-content > .card-title {
  margin-bottom: 8rpx;
}

.card-content > .card-badge {
  margin-bottom: 8rpx;
}

.card-content > .card-price-row {
  margin-bottom: 0;
}

.card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 
    1rpx 1rpx 0 rgba(0,0,0,0.35),
    0 2rpx 4rpx rgba(0,0,0,0.25);
  letter-spacing: -0.5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 62%;
}

.card-badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.15);
  font-weight: 500;
}

.badge-orange {
  
}

.badge-location {
  align-self: flex-start;
  max-width: 55%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge-blue {
  
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.15);
}

/* 价格对比行 */
.card-price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  align-self: flex-start;
}

.card-group-price {
  font-size: 42rpx;
  font-weight: 800;
  color: #FCD34D;
  text-shadow: 
    1rpx 1rpx 0 rgba(0,0,0,0.4),
    0 2rpx 6rpx rgba(0,0,0,0.3);
  letter-spacing: -1rpx;
}

.card-original-price {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
  text-decoration: line-through;
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.25);
}

.card-icon {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  z-index: 1;
}

.icon-gray {
  background: #D1D5DB;
}

/* 卡片SVG图标 */
.card-svg-icon {
  width: 54rpx;
  height: 54rpx;
}

/* 已截止图标 - 灰色半透明 */
.card-svg-icon.icon-faded {
  opacity: 0.4;
  filter: grayscale(100%);
}

/* 卡片信息 */
.card-info {
  padding: 12rpx 24rpx 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.info-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.creator-name {
  font-size: 20rpx;
  color: #999;
  background: #F3F4F6;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.date-range {
  font-size: 20rpx;
  color: #999;
  flex-shrink: 0;
}

.tag-yellow {
  background: linear-gradient(135deg, #FCD34D, #FBBF24);
  color: #333333;
  font-weight: 800;
}

.tag-gray {
  background: #E5E7EB;
  color: #6B7280;
  font-weight: 800;
}

.type-tag {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #555555;
}

.type-icon {
  font-size: 24rpx;
}

/* 类型图标SVG */
.type-icon-wrap {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-svg-icon {
  width: 24rpx;
  height: 24rpx;
}

.months-icon {
  font-size: 22rpx;
  line-height: 1;
}

.type-text {
  font-size: 24rpx;
}

.date-text {
  font-size: 22rpx;
  color: #888888;
}

.info-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.people-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatars {
  display: flex;
}

/* 头像圆圈 - CSS绘制 */
.avatar-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-left: -12rpx;
}

.avatar-circle::after {
  content: '';
  width: 16rpx;
  height: 16rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 50%;
}

.avatar-circle.blue::after {
  background: #3B82F6;
}

.avatar-circle:first-child {
  margin-left: 0;
}

.avatar-circle.blue {
  background: linear-gradient(135deg, #60A5FA, #3B82F6);
  color: #ffffff;
}

.people-count {
  font-size: 22rpx;
  font-weight: 800;
}

.count-num {
  font-size: 32rpx;
  font-weight: 800;
}

.people-count.orange {
  color: #F97316;
  font-weight: 800;
}

.people-count.gray {
  color: #9CA3AF;
}

.join-btn {
  padding: 10rpx 34rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FCD34D, #FBBF24);
  color: #333333;
  box-shadow: 0 4rpx 12rpx rgba(251, 191, 36, 0.3);
  flex-shrink: 0;
}

.join-btn.btn-disabled {
  background: #E5E7EB;
  color: #9CA3AF;
  box-shadow: none;
}

.image-expired .card-title,
.image-expired .card-group-price,
.image-expired .card-original-price {
  color: rgba(255, 255, 255, 0.5);
  text-shadow: none;
}

.image-expired .badge-location {
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.6);
}

/* 网格视图 */
.grid-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.grid-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.grid-image {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  min-height: 200rpx;
}

/* 网格图片伪元素已移除，新模板自带装饰 */

.gradient-0 {
  background: linear-gradient(135deg, #60A5FA, #22D3EE);
}

.gradient-1 {
  background: linear-gradient(135deg, #A78BFA, #F472B6);
}

.gradient-2 {
  background: linear-gradient(135deg, #FB923C, #F87171);
}

.gradient-3 {
  background: linear-gradient(135deg, #4ADE80, #34D399);
}

.gradient-4 {
  background: linear-gradient(135deg, #818CF8, #60A5FA);
}

.gradient-5 {
  background: linear-gradient(135deg, #FB7185, #F472B6);
}

.category-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: #EF4444;
  color: #ffffff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.grid-info {
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.grid-info > text {
  display: block;
}

.grid-title {
  display: block;
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  padding-bottom: 14rpx;
  margin-bottom: 14rpx;
  border-bottom: 1rpx solid #F0F0F0;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 72rpx;
}

.grid-price {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #EF4444;
  margin-bottom: 12rpx;
}

.meta-item {
  display: block;
  font-size: 22rpx;
  color: #999999;
  line-height: 1.6;
}

/* 列表视图 */
.list-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.list-card {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 24rpx;
  gap: 24rpx;
}

.list-left {
  width: 192rpx;
  height: 192rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 列表占位图 */
.image-placeholder {
  font-size: 60rpx;
  opacity: 0.5;
}

.image-placeholder-box {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 500;
}

.grid-thumb-img {
  width: 100%;
  display: block;
}

.list-thumb-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.list-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  box-sizing: border-box;
}

.list-right > text {
  display: block;
}

.list-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-desc {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-meta {
  display: block;
  margin-bottom: 4rpx;
}

.list-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #F97316;
  margin-top: 4rpx;
}

.list-original-price {
  font-size: 22rpx;
  font-weight: normal;
  color: #999999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  border-top: 1rpx solid #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex: 1;
  height: 100%;
  padding: 0;
}

/* 选中状态 */
.tab-item.active .tab-icon .nav-svg-icon {
  color: #111827;
}

.tab-item.active .tab-text {
  color: #111827;
  font-weight: 500;
}

/* 导航图标 */
.tab-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-svg-icon {
  width: 48rpx;
  height: 48rpx;
  color: #6B7280;
}

.tab-text {
  font-size: 22rpx;
  color: #6B7280;
}

.tab-center {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  margin-top: -32rpx;
}

.center-btn {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FFE500, #FDE047, #FCD34D);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(251, 191, 36, 0.3);
  transform: rotate(45deg);
}

/* 加号图标 */
.plus-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.plus-h {
  position: absolute;
  width: 36rpx;
  height: 6rpx;
  background: #111827;
  border-radius: 3rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
}

.plus-v {
  position: absolute;
  width: 6rpx;
  height: 36rpx;
  background: #111827;
  border-radius: 3rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* 点击反馈 */
.tab-item:active, .tab-center:active {
  opacity: 0.7;
}

/* 置灰发布按钮 */
.center-btn-disabled {
  opacity: 0.35;
  pointer-events: none;
}

.plus-disabled {
  opacity: 0.4;
}

/* 管理菜单 */
.ctx-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.ctx-menu {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx 60rpx;
}

.ctx-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.ctx-item {
  font-size: 30rpx;
  padding: 28rpx 0;
  text-align: center;
  border-bottom: 1rpx solid #F3F4F6;
}

.ctx-copy {
  color: #3B82F6;
}

.ctx-del {
  color: #EF4444;
  border-bottom: none;
}

.ctx-cancel {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
  text-align: center;
  padding: 20rpx;
  background: #F3F4F6;
  border-radius: 50rpx;
}

/* ====== 长按菜单弹出气泡 ====== */
.ctx-backdrop {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.3);
}
.ctx-popup {
  position: fixed;
  z-index: 1000;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
  width: 240rpx;
}
.ctx-popup.banner-ctx {
  width: 220rpx;
}
.ctx-row {
  display: flex;
  align-items: center;
  padding: 14rpx 22rpx;
  gap: 10rpx;
}
.ctx-row:active {
  background: #F3F4F6;
}
.ctx-icon {
  font-size: 28rpx;
  width: 34rpx;
  text-align: center;
}
.ctx-text {
  font-size: 26rpx;
  color: #333;
  white-space: nowrap;
}
.ctx-del-row .del-icon {
  color: #EF4444;
}
.ctx-del-row .del-text {
  color: #EF4444;
}
.ctx-divider {
  height: 1rpx;
  background: #E5E7EB;
  margin: 0 24rpx;
}

/* ====== 通用弹窗遮罩 ====== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 998;
}
.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  z-index: 999;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #F3F4F6;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1F2937;
}
.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9CA3AF;
  font-size: 32rpx;
}
.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}
.modal-btns {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx 32rpx;
  border-top: 1rpx solid #F3F4F6;
}
.modal-btns button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}
.btn-cancel {
  background: #F3F4F6;
  color: #666;
}
.btn-submit {
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #ffffff;
}

/* ====== Banner编辑器表单 ====== */
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  color: #4B5563;
  margin-bottom: 12rpx;
}
.required-star {
  color: #EF4444;
  margin-right: 4rpx;
}
.form-tip {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 12rpx;
}
.form-input {
  width: 100%;
  height: 72rpx;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}
.banner-image-single-row,
.banner-images-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.banner-preview-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.banner-preview-img {
  width: 100%;
  height: 100%;
}
.banner-preview-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 12rpx 0 12rpx;
  font-size: 20rpx;
}
.banner-upload-btn {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx dashed #D1D5DB;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #9CA3AF;
}
