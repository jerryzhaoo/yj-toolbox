/* 页面容器 */
.page {
  min-height: 100vh;
  background: #F5F4FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.page.scroll-locked {
  overflow: hidden;
}

/* 顶部搜索栏 */
.search-bar {
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
}

.search-input {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 50rpx;
  padding: 20rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 搜索图标 - CSS绘制 */
.icon-search {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #999999;
  border-radius: 50%;
  position: relative;
  margin-right: 20rpx;
}

.icon-search::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 3rpx;
  background: #999999;
  bottom: -4rpx;
  right: -6rpx;
  transform: rotate(45deg);
}

.search-input input {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.placeholder {
  color: #999999;
  font-size: 30rpx;
}

/* Banner轮播 */
.banner-container {
  padding: 0 32rpx;
  margin-bottom: 40rpx;
  margin-top: 12rpx;
  position: relative;
}

.banner {
  border-radius: 40rpx;
  overflow: hidden;
  height: 320rpx;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.banner-style0 {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 50%, #2563EB 100%);
}

.banner-style1 {
  background: linear-gradient(135deg, #06B6D4 0%, #38BDF8 50%, #0891B2 100%);
}

.banner-style2 {
  background: linear-gradient(135deg, #6366F1 0%, #818CF8 50%, #7C3AED 100%);
}

.banner-style3 {
  background: linear-gradient(135deg, #14B8A6 0%, #2DD4BF 50%, #10B981 100%);
}

.banner-style4 {
  background: linear-gradient(135deg, #2563EB 0%, #3B82F6 50%, #0EA5E9 100%);
}

/* Banner装饰 */
.banner::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: #FCD34D;
  border-radius: 50%;
  opacity: 0.8;
}

.banner::after {
  content: '';
  position: absolute;
  bottom: 40rpx;
  left: -60rpx;
  width: 160rpx;
  height: 160rpx;
  background: #FDE68A;
  border-radius: 50%;
  opacity: 0.6;
}

.banner-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding: 0 48rpx;
}

.banner-left {
  flex: 1;
}

.banner-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.banner-title .highlight {
  color: #FCD34D;
}

.banner-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 4rpx;
}

.banner-icon {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.15);
  position: relative;
  z-index: 1;
}

.icon-yellow {
  background: #FCD34D;
}

.icon-white {
  background: #ffffff;
}

.icon-char {
  font-size: 80rpx;
  line-height: 1;
}

/* SVG图标样式 */
.svg-icon {
  width: 80rpx;
  height: 80rpx;
}

/* Swiper容器 */
.banner-inner {
  border-radius: 40rpx;
  overflow: hidden;
}

.banner-slide {
  height: 100%;
  position: relative;
  overflow: hidden;
  background: #F3F4F6;
}
.banner-full-img {
  width: 100%;
  height: 100%;
}
.banner-deco {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}
.banner-deco-1 {
  width: 300rpx;
  height: 300rpx;
  background: #ffffff;
  top: -80rpx;
  right: -60rpx;
}
.banner-deco-2 {
  width: 200rpx;
  height: 200rpx;
  background: #ffffff;
  bottom: -60rpx;
  left: -40rpx;
}

/* Banner样式变体 */
.banner-slide.banner-style0 { background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 50%, #2563EB 100%); }
.banner-slide.banner-style1 { background: linear-gradient(135deg, #06B6D4 0%, #38BDF8 50%, #0891B2 100%); }
.banner-slide.banner-style2 { background: linear-gradient(135deg, #6366F1 0%, #818CF8 50%, #7C3AED 100%); }
.banner-slide.banner-style3 { background: linear-gradient(135deg, #14B8A6 0%, #2DD4BF 50%, #10B981 100%); }
.banner-slide.banner-style4 { background: linear-gradient(135deg, #2563EB 0%, #3B82F6 50%, #0EA5E9 100%); }

/* Banner指示器 */
.banner-dots {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
}

.dot.active {
  width: 32rpx;
  border-radius: 6rpx;
  background: #ffffff;
}

/* 分类标签栏 - 吸顶效果 */
.tabs-container {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  background: transparent;
  position: sticky;
  top: 0;
  z-index: 99;
  left: 0;
  right: 0;
  width: 100%;
  box-sizing: border-box;
}

/* 拼团中标题区 - 多彩竖条样式 */
.section-header {
  position: relative;
}

.header-content {
  position: relative;
  padding: 24rpx 16rpx 16rpx;
}

.header-title-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.header-bars {
  display: flex;
  gap: 8rpx;
}

.header-bar {
  width: 10rpx;
  height: 48rpx;
  border-radius: 10rpx;
}

.header-title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
}

.header-divider {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(168, 85, 247, 0.3), rgba(236, 72, 153, 0.15), transparent);
  margin: 0 16rpx;
}



/* 筛选按钮 */
.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filter-left {
  display: flex;
  gap: 16rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 28rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  color: #777777;
}

.filter-btn.active {
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #ffffff;
  font-weight: 500;
}

/* 视图切换 */
.view-toggle {
  display: flex;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50rpx;
  padding: 8rpx;
}

.toggle-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
  color: #999999;
  transition: all 0.2s;
}

.toggle-grid {
  font-size: 24rpx;
  letter-spacing: -2rpx;
}

.toggle-list {
  font-size: 28rpx;
}

.toggle-btn.active {
  background: #333333;
  color: #ffffff;
}

/* 内容列表 */
.content-list {
  padding: 0 32rpx;
}

/* 活动卡片 */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.activity-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-image {
  border-radius: 0;
  height: 200rpx;
  position: relative;
  overflow: hidden;
}

/* 确保文字在最上层 - 伪元素在内容下方 */
.card-image::before,
.card-image::after {
  z-index: 0;
  pointer-events: none;
}

/* ==================== 活动卡片背景模板 ==================== */

/* 模板1: 经典渐变 - 右上角圆形装饰 */
.card-template1 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
}

.card-template1::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.card-template1::after {
  content: '';
  position: absolute;
  bottom: -100rpx;
  left: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* 模板2: 双圆形 - 上下对角装饰 */
.card-template2 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  position: relative;
  overflow: hidden;
}

.card-template2::before {
  content: '';
  position: absolute;
  top: -100rpx;
  left: -60rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.card-template2::after {
  content: '';
  position: absolute;
  bottom: -120rpx;
  right: -80rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* 模板3: 动感斜向 - 斜向条纹 */
.card-template3 {
  background: linear-gradient(160deg, #fa709a 0%, #fee140 100%);
  position: relative;
  overflow: hidden;
}

.card-template3::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 30rpx,
    rgba(255, 255, 255, 0.08) 30rpx,
    rgba(255, 255, 255, 0.08) 60rpx
  );
  pointer-events: none;
  z-index: 0;
}

.card-template3::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* 模板4: 中心发光 - 从中心向外扩散 */
.card-template4 {
  background: radial-gradient(circle at 30% 30%, #4facfe 0%, #00f2fe 100%);
  position: relative;
  overflow: hidden;
}

.card-template4::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.card-template4::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -80rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* 模板5: 多层叠加 - 大小不一的圆形 */
.card-template5 {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  position: relative;
  overflow: hidden;
}

.card-template5::before {
  content: '';
  position: absolute;
  top: -60rpx;
  left: 30%;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.card-template5::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  right: 20%;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* 模板6: 渐变点阵 - 散落的小圆点 */
.card-template6 {
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
  position: relative;
  overflow: hidden;
}

.card-template6::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  box-shadow: 
    -80rpx 60rpx 0 rgba(255, 255, 255, 0.15),
    -40rpx 120rpx 0 rgba(255, 255, 255, 0.1),
    80rpx -40rpx 0 rgba(255, 255, 255, 0.12);
  pointer-events: none;
  z-index: 0;
}

.card-template6::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: 10%;
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* 模板7: 对角分割 - 两种颜色对角 */
.card-template7 {
  background: linear-gradient(135deg, #fa709a 0%, #f6d365 100%);
  position: relative;
  overflow: hidden;
}

.card-template7::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  box-shadow: -60rpx 80rpx 0 rgba(255, 255, 255, 0.1);
  pointer-events: none;
  z-index: 0;
}

.card-template7::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  pointer-events: none;
  z-index: 0;
}

/* ==================== 网格卡片背景模板 ==================== */

